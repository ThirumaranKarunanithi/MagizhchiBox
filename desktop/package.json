{
  "name": "magizhchi-box-desktop",
  "version": "1.0.0",
  "description": "Magizhchi Box Desktop Sync Client",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite --port 3100\" \"wait-on http://localhost:3100 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "chokidar": "^3.6.0",
    "form-data": "^4.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.magizhchi.box.desktop",
    "productName": "Magizhchi Box",
    "directories": { "output": "release" },
    "files": ["dist/**", "electron/**", "assets/**"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
